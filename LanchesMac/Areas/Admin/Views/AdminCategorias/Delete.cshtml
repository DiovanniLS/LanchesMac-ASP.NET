@model LanchesMac.Models.Categoria

@{
    ViewData["Title"] = "Excluir Categoria";
}

<div class="container">

    <div class="delete-card">

        <div class="text-center mb-4">

            <h1 class="delete-title">
                🗑 Excluir Categoria
            </h1>

            <p class="text-muted">
                Esta ação não poderá ser desfeita.
            </p>

        </div>

        <div class="alert alert-danger">

            <strong>⚠ Atenção!</strong>
            Você está prestes a excluir esta categoria permanentemente.

        </div>

        <div class="info-box">

            <div class="info-item">

                <span class="info-label">
                    Nome da Categoria
                </span>

                <span class="info-value">
                    @Model.CategoriaNome
                </span>

            </div>

            <div class="info-item">

                <span class="info-label">
                    Descrição
                </span>

                <span class="info-value">
                    @Model.Descricao
                </span>

            </div>

        </div>

        <form asp-action="Delete" class="mt-4">

            <input type="hidden"
                   asp-for="CategoriaId" />

            <div class="d-flex gap-3">

                <button type="submit"
                        class="btn-delete">

                    🗑 Confirmar Exclusão

                </button>

                <a asp-action="Index"
                   class="btn-back">

                    ↩ Cancelar

                </a>

            </div>

        </form>

    </div>

</div>

<style>

    .delete-card {
        max-width: 800px;
        margin: auto;
        background: white;
        padding: 40px;
        border-radius: 24px;
        box-shadow: 0 15px 40px rgba(0,0,0,.08);
    }

    .delete-title {
        font-size: 2.3rem;
        font-weight: 700;
        color: #dc3545;
    }

    .info-box {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .info-item {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 20px;
    }

    .info-label {
        display: block;
        color: #777;
        font-size: .9rem;
        font-weight: 600;
        margin-bottom: 8px;
        text-transform: uppercase;
    }

    .info-value {
        font-size: 1.1rem;
        font-weight: 600;
        color: #222;
    }

    .btn-delete {
        background: #dc3545;
        border: none;
        color: white;
        padding: 12px 24px;
        border-radius: 14px;
        font-weight: 600;
    }

        .btn-delete:hover {
            background: #bb2d3b;
        }

    .btn-back {
        background: #f1f1f1;
        color: #222;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: 14px;
        font-weight: 600;
    }

        .btn-back:hover {
            color: black;
        }

</style>