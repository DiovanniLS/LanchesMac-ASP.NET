@{
    ViewData["Title"] = "Gráfico de Vendas";
}

<title>
    @ViewData["Title"]
</title>

<script type="text/javascript"
        src="https://www.gstatic.com/charts/loader.js">
</script>

<div class="container mt-4">

    <div class="card shadow border-0 rounded-4">

        <div class="card-header bg-success text-white p-4">

            <div class="d-flex justify-content-between align-items-center flex-wrap">

                <div>
                    <h2 class="mb-1">
                        📊 Relatório de Vendas
                    </h2>

                    <small>
                        Quantidade vendida e faturamento por lanche
                    </small>
                </div>

                <span class="badge bg-light text-success fs-6 px-3 py-2">
                    Últimos 360 dias
                </span>

            </div>

        </div>

        <div class="card-body">

            <div id="loading"
                 class="text-center py-5">

                <div class="spinner-border text-success mb-3"
                     role="status">
                </div>

                <h5 class="text-muted">
                    Carregando dados...
                </h5>

            </div>

            <div id="chart_div"
                 style="width:100%; height:600px;">
            </div>

        </div>

    </div>

</div>

<script>

    google.charts.load('current', {
        packages: ['corechart', 'bar']
    });

    google.charts.setOnLoadCallback(CarregaDados);

    function CarregaDados() {

        $.ajax({

            url: '@Url.Action("VendasLanches", "AdminGrafico", new { area = "Admin" })',

            data: {
                dias: 360
            },

            type: 'GET',

            dataType: 'json',

            success: function (data) {

                $('#loading').fadeOut(300);

                GraficoVendasLanches(data);
            },

            error: function () {

                $('#loading').hide();

                toastr.error(
                    "Não foi possível carregar os dados do gráfico."
                );
            }
        });
    }

    function GraficoVendasLanches(data) {

        let dataArray = [
            ['Lanche', 'Quantidade', 'Valor Total (R$)']
        ];

        $.each(data, function (i, item) {

            dataArray.push([
                item.lancheNome,
                item.lanchesQuantidade,
                item.lanchesValorTotal
            ]);

        });

        let chartData =
            google.visualization.arrayToDataTable(dataArray);

        let options = {

            title: 'Vendas por Lanche',

            titleTextStyle: {
                fontSize: 20,
                bold: true
            },

            chartArea: {
                width: '65%',
                height: '75%'
            },

            colors: [
                '#198754',
                '#ffc107'
            ],

            legend: {
                position: 'top',
                textStyle: {
                    fontSize: 13
                }
            },

            hAxis: {
                title: 'Quantidade / Valor',
                minValue: 0,
                textStyle: {
                    fontSize: 12
                }
            },

            vAxis: {
                title: 'Lanches',
                textStyle: {
                    fontSize: 12
                }
            },

            animation: {
                startup: true,
                duration: 1200,
                easing: 'out'
            },

            backgroundColor: 'transparent'
        };

        let chart = new google.visualization.BarChart(
            document.getElementById('chart_div')
        );

        chart.draw(chartData, options);

        window.addEventListener('resize', function () {
            chart.draw(chartData, options);
        });
    }

</script>