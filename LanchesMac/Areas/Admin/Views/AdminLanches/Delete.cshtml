@model LanchesMac.Models.Lanche

@{
    ViewData["Title"] = "Excluir Lanche";
}

<div class="container mt-5">

    <div class="delete-card">

        <div class="text-center mb-4">

            <div class="warning-icon">
                ⚠️
            </div>

            <h1 class="page-title">
                Excluir Lanche
            </h1>

            <p class="text-muted">
                Tem certeza que deseja excluir este lanche?
            </p>

        </div>

        <div class="row align-items-center">

            <div class="col-md-4 text-center">

                <img src="~/images/produtos/@Model.ImagemUrl"
                     alt="@Model.Nome"
                     class="product-image" />

            </div>

            <div class="col-md-8">

                <div class="info-box">

                    <div class="info-item">
                        <span class="label">Nome</span>
                        <span>@Model.Nome</span>
                    </div>

                    <div class="info-item">
                        <span class="label">Descrição Curta</span>
                        <span>@Model.DescricaoCurta</span>
                    </div>

                    <div class="info-item">
                        <span class="label">Descrição Detalhada</span>
                        <span>@Model.DescricaoDetalhada</span>
                    </div>

                    <div class="info-item">
                        <span class="label">Preço</span>
                        <span>@Model.Preco.ToString("C")</span>
                    </div>

                    <div class="info-item">
                        <span class="label">Categoria</span>
                        <span>@Model.Categoria?.CategoriaNome</span>
                    </div>

                    <div class="info-item">
                        <span class="label">Estoque</span>

                        @if (Model.EmEstoque)
                        {
                            <span class="badge-stock available">
                                Em estoque
                            </span>
                        }
                        else
                        {
                            <span class="badge-stock unavailable">
                                Sem estoque
                            </span>
                        }
                    </div>

                </div>

            </div>

        </div>

        <form asp-action="Delete" class="mt-4">

            <input type="hidden" asp-for="LancheId" />

            <div class="buttons-wrapper">

                <button type="submit" class="btn-delete">
                    🗑️ Confirmar Exclusão
                </button>

                <a asp-action="Index"
                   class="btn-back">
                    ← Voltar
                </a>

            </div>

        </form>

    </div>

</div>

<style>

    .delete-card {
        max-width: 950px;
        margin: auto;
        background: white;
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 15px 40px rgba(0,0,0,.08);
    }

    .warning-icon {
        font-size: 4rem;
    }

    .page-title {
        font-size: 2.5rem;
        font-weight: 700;
    }

    .product-image {
        width: 100%;
        max-width: 250px;
        border-radius: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,.12);
    }

    .info-box {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .info-item {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 12px 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .label {
        font-weight: 700;
        color: #555;
    }

    .badge-stock {
        padding: 6px 14px;
        border-radius: 999px;
        font-weight: 600;
    }

    .available {
        background: #d1fae5;
        color: #065f46;
    }

    .unavailable {
        background: #fee2e2;
        color: #991b1b;
    }

    .buttons-wrapper {
        display: flex;
        gap: 15px;
    }

    .btn-delete {
        flex: 1;
        border: none;
        padding: 14px;
        border-radius: 14px;
        background: linear-gradient(135deg,#dc3545,#b91c1c);
        color: white;
        font-weight: 700;
        transition: .3s;
    }

        .btn-delete:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(220,53,69,.25);
        }

    .btn-back {
        flex: 1;
        text-align: center;
        text-decoration: none;
        background: #f1f3f5;
        color: #333;
        padding: 14px;
        border-radius: 14px;
        font-weight: 700;
        transition: .3s;
    }

        .btn-back:hover {
            background: #e9ecef;
            color: #111;
        }

</style>