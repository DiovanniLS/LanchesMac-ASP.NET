@{
    ViewData["Title"] = "Gerenciar Imagens";
}

<div class="card shadow border-0 rounded-4">
    <div class="card-header bg-dark text-white p-4">
        <h2 class="mb-0">🖼️ Gerenciamento de Imagens</h2>
    </div>

    <div class="card-body">

        @if (ViewData["Erro"] != null)
        {
            <div class="alert alert-danger">
                @ViewData["Erro"]
            </div>
        }

        <form asp-action="UploadFiles"
              method="post"
              enctype="multipart/form-data">

            <div class="mb-3">
                <label class="form-label fw-bold">
                    Selecione até 10 imagens
                </label>

                <input type="file"
                       name="files"
                       multiple
                       accept=".jpg,.jpeg,.png,.gif"
                       class="form-control" />
            </div>

            <div class="d-flex gap-2">

                <button type="submit"
                        class="btn btn-success">
                    ⬆️ Enviar Imagens
                </button>

                <a asp-action="GetImagens"
                   class="btn btn-primary">
                    🖼️ Ver Imagens
                </a>

            </div>

        </form>

    </div>

</div>
