@model Lanche

<div class="col-md-6 col-lg-4 mb-4">

    <div class="lanche-card h-100">

        <!-- IMAGEM -->
        <div class="image-wrapper">

            <img src="@Model.ImagemUrl"
                 class="lanche-image"
                 alt="@Model.Nome">

        </div>

        <!-- CONTEÚDO -->
        <div class="card-content">

            <!-- TOPO -->
            <div class="card-header-custom">

                <h4 class="lanche-title">
                    @Model.Nome
                </h4>

                <span class="price-badge">
                    @Model.Preco.ToString("c")
                </span>

            </div>

            <!-- DESCRIÇÃO -->
            <p class="lanche-description">
                @Model.DescricaoCurta
            </p>

            <!-- BOTÃO -->
            <div class="mt-auto">

                <a class="details-button"
                   asp-controller="Lanche"
                   asp-action="Details"
                   asp-route-lancheId="@Model.LancheId">

                    Ver Detalhes 🍟

                </a>

            </div>

        </div>

    </div>

</div>

<style>

    .lanche-card {
        background: #fff;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        transition: 0.35s;
        display: flex;
        flex-direction: column;
        min-height: 100%;
    }

        .lanche-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 18px 40px rgba(0,0,0,0.12);
        }

    /* IMAGEM */

    .image-wrapper {
        height: 220px;
        overflow: hidden;
        background: #f5f5f5;
    }

    .lanche-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: 0.4s;
    }

    .lanche-card:hover .lanche-image {
        transform: scale(1.05);
    }

    /* CONTEÚDO */

    .card-content {
        padding: 22px;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .card-header-custom {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 14px;
    }

    .lanche-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: #222;
        margin: 0;
        line-height: 1.3;
        flex: 1;
    }

    .price-badge {
        background: #ffcc00;
        color: #111;
        padding: 8px 12px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 0.95rem;
        white-space: nowrap;
    }

    /* DESCRIÇÃO */

    .lanche-description {
        color: #666;
        line-height: 1.7;
        display: -webkit-box;
        -webkit-line-clamp: 4;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 20px;
    }

    /* BOTÃO */

    .details-button {
        display: block;
        width: 100%;
        text-align: center;
        background: linear-gradient(135deg, #111, #2a2a2a);
        color: white;
        padding: 14px;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
    }

        .details-button:hover {
            background: linear-gradient(135deg, #222, #333);
            color: #ffcc00;
            transform: translateY(-2px);
        }

    /* MOBILE */

    @@media (max-width: 768px) {

        .image-wrapper {
            height: 200px;
        }

        .lanche-title {
            font-size: 1.2rem;
        }

        .card-content {
            padding: 18px;
        }
    }

</style>