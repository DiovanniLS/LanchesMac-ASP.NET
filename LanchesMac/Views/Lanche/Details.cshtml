@model Lanche

<div class="container mt-5">

    <div class="details-card">

        <div class="row g-5 align-items-center">

            <!-- IMAGEM -->
            <div class="col-lg-6">

                <div class="details-image-wrapper">

                    <img src="@Model.ImagemUrl"
                         class="details-image"
                         alt="@Model.Nome" />

                </div>

            </div>

            <!-- INFORMAÇÕES -->
            <div class="col-lg-6">

                <div class="details-content">

                    <span class="category-badge">
                        🍔 @Model.Categoria?.CategoriaNome
                    </span>

                    <h1 class="details-title mt-3">
                        @Model.Nome
                    </h1>

                    <p class="details-description">
                        @Model.DescricaoDetalhada
                    </p>

                    <div class="price-section">

                        <span class="price-label">
                            Preço
                        </span>

                        <h2 class="details-price">
                            @Model.Preco.ToString("c")
                        </h2>

                    </div>

                    <form asp-controller="CarrinhoCompra"
                          asp-action="AdicionarItemNoCarrinhoCompra"
                          method="post">

                        <input type="hidden"
                               name="lancheId"
                               value="@Model.LancheId" />

                        <input type="hidden"
                               id="quantidade"
                               name="quantidade"
                               value="1" />

                        <div class="quantity-card">

                            <label class="fw-bold mb-3">
                                Quantidade
                            </label>

                            <div class="quantity-selector">

                                <button type="button"
                                        class="qty-btn"
                                        onclick="diminuir()">
                                    -
                                </button>

                                <span id="quantidadeTexto">1</span>

                                <button type="button"
                                        class="qty-btn"
                                        onclick="aumentar()">
                                    +
                                </button>

                            </div>

                        </div>

                        <div class="total-preview mt-4">

                            <span>Total</span>

                            <h3 id="valorTotal">
                                @Model.Preco.ToString("c")
                            </h3>

                        </div>

                        

                    </form>

                    <!-- BOTÕES -->
                    <div class="buttons-wrapper">

                        @if (Model.QuantidadeEstoque > 0)
                        {
                            <a class="cart-button"
                               asp-controller="CarrinhoCompra"
                               asp-action="AdicionarItemNoCarrinhoCompra"
                               asp-route-lancheId="@Model.LancheId">

                                🛒 Adicionar ao Carrinho

                            </a>
                        }
                        else
                        {
                            <button class="btn btn-secondary" disabled>
                                Sem estoque
                            </button>
                        }

                        <a class="back-button"
                           asp-controller="Lanche"
                           asp-action="List">

                            ← Voltar ao Cardápio

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<script>

    let quantidade = 1;
    const precoUnitario = @Model.Preco.ToString(System.Globalization.CultureInfo.InvariantCulture);

    function atualizarTela() {

        document.getElementById("quantidade").value = quantidade;
        document.getElementById("quantidadeTexto").innerText = quantidade;

        let total = quantidade * precoUnitario;

        document.getElementById("valorTotal")
            .innerText = total.toLocaleString(
                'pt-BR',
                {
                    style: 'currency',
                    currency: 'BRL'
                });
    }

        const estoqueDisponivel = @Model.QuantidadeEstoque;

    function aumentar() {

        if (quantidade < estoqueDisponivel) {
            quantidade++;
            atualizarTela();
        }
    }

    function diminuir() {

        if (quantidade > 1) {
            quantidade--;
            atualizarTela();
        }
    }

</script>

<style>

    .details-card {
        background: white;
        border-radius: 32px;
        padding: 40px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.08);
    }

    /* IMAGEM */

    .details-image-wrapper {
        overflow: hidden;
        border-radius: 28px;
        background: #f5f5f5;
    }

    .details-image {
        width: 100%;
        height: 500px;
        object-fit: cover;
        transition: 0.4s;
    }

        .details-image:hover {
            transform: scale(1.04);
        }

    /* CONTEÚDO */

    .details-content {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .category-badge {
        display: inline-block;
        width: fit-content;
        background: #ffcc00;
        color: #111;
        padding: 8px 16px;
        border-radius: 999px;
        font-weight: 700;
        font-size: 0.95rem;
    }

    .details-title {
        font-size: 3rem;
        font-weight: 700;
        color: #222;
        line-height: 1.2;
    }

    .details-description {
        color: #666;
        line-height: 1.9;
        font-size: 1.05rem;
    }

    /* PREÇO */

    .price-section {
        margin-top: 10px;
    }

    .price-label {
        color: #888;
        font-size: 0.95rem;
    }

    .details-price {
        font-size: 2.6rem;
        font-weight: 700;
        color: #111;
    }

    /* BOTÕES */

    .buttons-wrapper {
        display: flex;
        gap: 15px;
        margin-top: 25px;
        flex-wrap: wrap;
    }

    .cart-button {
        flex: 1;
        text-align: center;
        background: linear-gradient(135deg, #111, #2a2a2a);
        color: white;
        padding: 16px 24px;
        border-radius: 18px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
    }

        .cart-button:hover {
            color: #ffcc00;
            transform: translateY(-3px);
        }

    .back-button {
        flex: 1;
        text-align: center;
        background: #f3f3f3;
        color: #222;
        padding: 16px 24px;
        border-radius: 18px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
    }

        .back-button:hover {
            background: #e7e7e7;
            color: #111;
        }

        /*btn quantidade*/

    .quantity-card {
        margin-top: 20px;
    }

    .quantity-selector {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .qty-btn {
        width: 45px;
        height: 45px;
        border: none;
        border-radius: 12px;
        background: #111;
        color: white;
        font-size: 1.4rem;
        font-weight: bold;
        transition: 0.3s;
    }

        .qty-btn:hover {
            background: #222;
            color: #ffcc00;
        }

    #quantidadeTexto {
        font-size: 1.5rem;
        font-weight: 700;
        min-width: 30px;
        text-align: center;
    }

    .total-preview {
        background: #f7f7f7;
        padding: 20px;
        border-radius: 16px;
    }

        .total-preview span {
            color: #777;
        }

        .total-preview h3 {
            margin-top: 5px;
            font-weight: 700;
        }

    /* RESPONSIVO */

    @@media (max-width: 768px) {

        .details-card {
            padding: 24px;
        }

        .details-image {
            height: 320px;
        }

        .details-title {
            font-size: 2rem;
        }

        .buttons-wrapper {
            flex-direction: column;
        }
    }



</style>